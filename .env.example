# ============================================
# TASKCHI — Environment Variables
# ============================================

# Database (PostgreSQL on Railway)
DATABASE_URL="postgresql://user:password@localhost:5432/taskchi?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"

# Groq AI (https://console.groq.com)
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GROQ_MODEL="llama-3.3-70b-versatile"

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN="123456789:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxx"
TELEGRAM_ADMIN_CHAT_ID="-100xxxxxxxxxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Taskchi"

# Socket.io
SOCKET_PORT=3001

# Commission settings
COMMISSION_PERCENT=5
COMMISSION_MAX_SOMONI=100

# Email SMTP — для сброса пароля (Gmail: включите 2FA → App Password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Taskchi <noreply@taskchi.tj>"

# Eskiz.uz SMS (https://eskiz.uz)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Railway (auto-set in production)
# PORT=3000
# RAILWAY_ENVIRONMENT=production
